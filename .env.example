# ── Safety ───────────────────────────────────────────────────────────────────
DRY_RUN=true

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ── AI Models ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=your_groq_api_key
GROQ_API_KEY_2=your_secondary_groq_key_optional
GROQ_MODEL=llama-3.3-70b-versatile

# ── Job Discovery ─────────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
ADZUNA_COUNTRY=gb
ADZUNA_MAX_RESULTS=50

# ── Gmail OAuth ───────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# ── Hunter.io (optional, for HR email lookup) ────────────────────────────────
HUNTER_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# LOCAL: keep as localhost. RAILWAY: set APP_BASE_URL to your frontend service URL.
# The API's own URL is auto-detected from x-forwarded-host (no API_BASE_URL needed on Railway).
APP_BASE_URL=http://localhost:3000
WHATSAPP_SERVICE_URL=http://localhost:3001
RATE_LIMIT_DELAY=2.0
